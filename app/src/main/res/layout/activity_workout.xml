<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D">

    ```
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:src="@drawable/gymflow_logo"
            android:scaleType="fitCenter"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WORKOUT PLANS"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose Your Training"
            android:textColor="#FFC107"
            android:textSize="16sp"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnChest"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🏋️ CHEST WORKOUT"
            android:textStyle="bold"
            android:textColor="#000000"
            android:backgroundTint="#FFC107"/>

        <Button
            android:id="@+id/btnArms"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="💪 ARMS WORKOUT"
            android:textStyle="bold"
            android:textColor="#000000"
            android:backgroundTint="#FFD54F"/>

        <Button
            android:id="@+id/btnShoulders"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="🔥 SHOULDERS WORKOUT"
            android:textStyle="bold"
            android:textColor="#000000"
            android:backgroundTint="#FFC107"/>

        <Button
            android:id="@+id/btnLegs"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="🦵 LEGS WORKOUT"
            android:textStyle="bold"
            android:textColor="#000000"
            android:backgroundTint="#FFD54F"/>

        <Button
            android:id="@+id/btnCardio"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="🏃 CARDIO WORKOUT"
            android:textStyle="bold"
            android:textColor="#000000"
            android:backgroundTint="#FFC107"/>

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="BACK"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#333333"/>

    </LinearLayout>
    ```

</ScrollView>
