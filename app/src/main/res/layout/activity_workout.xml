<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏋️ Workout Plans"
            android:textSize="28sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnChest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💪 Chest Workout"
            android:layout_marginTop="24dp" />

        <Button
            android:id="@+id/btnArms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💪 Arms Workout"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnShoulders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏋️ Shoulders Workout"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnLegs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🦵 Legs Workout"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnCardio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏃 Cardio Workout"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⬅️ Back"
            android:layout_marginTop="20dp" />

    </LinearLayout>

</ScrollView>